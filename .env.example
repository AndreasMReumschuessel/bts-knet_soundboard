# BTS Soundboard — environment variables (copy to `.env` as needed).
# Only `BTS_WS_URL` is required at runtime by clients; everything else has
# sensible defaults baked into `@bts-soundboard/shared/constants`.

# Backend HTTP port (REST). Default: 8080.
BTS_SERVER_PORT=8080

# WebSocket URL clients connect to. Default: ws://localhost:8080/ws
BTS_WS_URL=ws://localhost:8080/ws

# Vite dev-server port for the PWA / Electron renderer. Default: 5173.
BTS_WEB_PORT=5173

# Directory the server stores sound files in. Default: ./data/sounds
BTS_SOUNDS_DIR=./data/sounds
