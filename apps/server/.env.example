# BTS Soundboard — server environment variables (copy to .env as needed).
# All have sensible defaults from @bts-soundboard/shared.

# Backend HTTP port (REST + WS). Default: 8080.
BTS_SERVER_PORT=8080

# Directory the server stores sound files in. Default: ./data/sounds
# (catalog.json is written to this dir's parent, i.e. ./data/catalog.json).
BTS_SOUNDS_DIR=./data/sounds
