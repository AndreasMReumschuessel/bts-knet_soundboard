# BTS Soundboard — Desktop (Electron) env.
# Copy to .env if you need to override defaults; these are read by the Electron
# main process. The PWA renderer reads its own env (BTS_WS_URL, etc.) separately.

# Force dev mode: load http://localhost:5173 instead of the built PWA.
# Either of these enables dev mode:
# NODE_ENV=development
# BTS_DEV=1

# Vite dev-server port the renderer is served on (dev mode only). Default: 5173.
# BTS_WEB_PORT=5173
