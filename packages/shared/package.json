{
  "name": "@bts-soundboard/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared TypeScript types + Zod schemas for BTS Soundboard (WS events, REST DTOs, sound metadata).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.js"
    },
    "./ws": {
      "types": "./dist/ws.d.ts",
      "import": "./dist/ws.js"
    },
    "./rest": {
      "types": "./dist/rest.d.ts",
      "import": "./dist/rest.js"
    },
    "./sound": {
      "types": "./dist/sound.d.ts",
      "import": "./dist/sound.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
